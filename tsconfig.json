{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2023",
        "lib": [
            "ES2023"
        ],
        "typeRoots": [
            "./node_modules/@types"
        ],
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "forceConsistentCasingInFileNames": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "allowJs": true,
        "resolveJsonModule": true,
        "types": [
            "node"
        ],
        "outDir": "./dist",
        "baseUrl": "./",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@generated/*": [
                "src/generated/*"
            ]
        },
        "sourceMap": true,
        "declaration": true,
        "incremental": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "removeComments": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "prisma.config.ts",
        "**/*.spec.ts",
        "**/*.test.ts"
    ]
}